# sync-to-readwise environment variables.
#
# Preferred: `doppler run -- <cmd>` injects these from sync-to-readwise/dev.
# Fallback: copy this file to .env for plain-env local runs (e.g. CI).
#
# Third-party tokens use their conventional unprefixed names so Doppler
# secrets line up with upstream docs. Internal config is prefixed SYNCRW_.

# Required
READWISE_TOKEN=                      # https://readwise.io/access_token
YOUTUBE_OAUTH_CLIENT_ID=             # Google Cloud → Credentials → OAuth client (Desktop)
YOUTUBE_OAUTH_CLIENT_SECRET=

# Optional
SYNCRW_LOG_LEVEL=INFO
SYNCRW_DATA_DIR=/data
